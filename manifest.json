{
  "manifest_version": 3,
  "name": "SpoilerShield",
  "version": "1.0.0",
  "description": "Automatically blur content when spoiler keywords are detected on YouTube, Twitter/X, and Reddit.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://old.reddit.com/*"
  ],
  "action": {
    "default_popup": "/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["styles/style.css"],
      "run_at": "document_idle"
    }
  ]
}